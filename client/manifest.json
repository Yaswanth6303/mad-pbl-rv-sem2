{
  "name": "RecipeVerse: Smart Food Recipe Explorer",
  "short_name": "RecipeVerse",
  "description": "Explore, plan, and cook premium recipes from around the world with smart AI recommendations and offline support.",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/",
  "id": "com.recipeverse.app",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "orientation": "any",
  "theme_color": "#F97316",
  "background_color": "#FFF8EE",
  "categories": ["food", "lifestyle", "productivity"],
  "icons": [
    {
      "src": "/assets/icons/logo_192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/logo_512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/icons/maskable_icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Search Recipes",
      "short_name": "Search",
      "description": "Jump straight to recipe search",
      "url": "/",
      "icons": [{ "src": "/assets/icons/logo_192.png", "sizes": "192x192" }]
    },
    {
      "name": "Favorites",
      "short_name": "Favs",
      "description": "View your saved recipes",
      "url": "/favorites",
      "icons": [{ "src": "/assets/icons/logo_192.png", "sizes": "192x192" }]
    },
    {
      "name": "Meal Planner",
      "short_name": "Planner",
      "description": "Check your schedule",
      "url": "/planner",
      "icons": [{ "src": "/assets/icons/logo_192.png", "sizes": "192x192" }]
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  }
}
