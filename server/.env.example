PORT=3000
SPOONACULAR_API_KEY=your_spoonacular_api_key
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# PostgreSQL — use either DATABASE_URL or the discrete PG* vars
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recipeverse
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=recipeverse
# PGSSL=false
